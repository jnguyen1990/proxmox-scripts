#!/usr/bin/env bash

# ============================================================================
# Generate a single self-contained deploy script from modular sources
#
# Usage:
#   cp deploy.conf.example deploy.conf
#   vim deploy.conf  # fill in your values
#   ./generate       # outputs dist/deploy-{repo-name}.sh
# ============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Load config ─────────────────────────────────────────────────────────────
CONFIG_FILE="${SCRIPT_DIR}/deploy.conf"
if [[ ! -f "${CONFIG_FILE}" ]]; then
  echo "Error: deploy.conf not found."
  echo "Run: cp deploy.conf.example deploy.conf && vim deploy.conf"
  exit 1
fi

# shellcheck source=/dev/null
source "${CONFIG_FILE}"

if [[ -z "${REPO_NAME:-}" ]]; then
  echo "Error: REPO_NAME is required in deploy.conf"
  exit 1
fi

# Apply defaults
GITHUB_USER="${GITHUB_USER:-jnguyen1990}"
RUBY_VERSION="${RUBY_VERSION:-3.3.11}"
DEBIAN_TEMPLATE="${DEBIAN_TEMPLATE:-debian-12-standard}"
APP_PORT="${APP_PORT:-3000}"
LXC_RAM="${LXC_RAM:-1024}"
LXC_DISK="${LXC_DISK:-4}"
LXC_CORES="${LXC_CORES:-1}"
STORAGE="${STORAGE:-local-lvm}"
APP_DIR="/opt/${REPO_NAME}"
REPO_URL="git@github.com:${GITHUB_USER}/${REPO_NAME}.git"
CF_SUBDOMAIN="${CF_SUBDOMAIN:-${REPO_NAME}}"
NGINX_LISTEN="80"
[[ -n "${CF_API_TOKEN:-}" ]] && NGINX_LISTEN="127.0.0.1:80"

# ── Prepare output ──────────────────────────────────────────────────────────
mkdir -p "${SCRIPT_DIR}/dist"
OUTPUT="${SCRIPT_DIR}/dist/deploy-${REPO_NAME}.sh"

# ── Helper to strip shebangs from lib files ─────────────────────────────────
strip_shebang() {
  sed '1{/^#!/d}' "$1"
}

# ── Helper to process templates with conditionals ───────────────────────────
process_template() {
  local file="$1"
  local content
  content=$(cat "${file}")

  # Variable substitution
  content=$(echo "${content}" | sed \
    -e "s|{{REPO_NAME}}|${REPO_NAME}|g" \
    -e "s|{{APP_PORT}}|${APP_PORT}|g" \
    -e "s|{{APP_DIR}}|${APP_DIR}|g" \
    -e "s|{{RUBY_VERSION}}|${RUBY_VERSION}|g" \
    -e "s|{{GITHUB_USER}}|${GITHUB_USER}|g" \
    -e "s|{{TUNNEL_ID}}|\${TUNNEL_ID}|g" \
    -e "s|{{CF_DOMAIN}}|${CF_DOMAIN:-}|g" \
    -e "s|{{CF_SUBDOMAIN}}|${CF_SUBDOMAIN}|g" \
    -e "s|{{NGINX_LISTEN}}|${NGINX_LISTEN}|g")

  # Conditional blocks
  if [[ -n "${CF_API_TOKEN:-}" ]]; then
    content=$(echo "${content}" | sed '/{{#CLOUDFLARE}}/d; /{{\/CLOUDFLARE}}/d')
    content=$(echo "${content}" | sed '/{{#NO_CLOUDFLARE}}/,/{{\/NO_CLOUDFLARE}}/d')
  else
    content=$(echo "${content}" | sed '/{{#CLOUDFLARE}}/,/{{\/CLOUDFLARE}}/d')
    content=$(echo "${content}" | sed '/{{#NO_CLOUDFLARE}}/d; /{{\/NO_CLOUDFLARE}}/d')
  fi

  echo "${content}"
}

# ── Build the single-file script ────────────────────────────────────────────
{
  cat << 'HEADER'
#!/usr/bin/env bash
# ============================================================================
# Auto-generated deploy script
# Generated by: ./generate
# ============================================================================

set -euo pipefail
HEADER

  echo ""
  echo "# ── Baked Configuration ──"
  echo "REPO_NAME=\"${REPO_NAME}\""
  echo "GITHUB_USER=\"${GITHUB_USER}\""
  echo "RUBY_VERSION=\"${RUBY_VERSION}\""
  echo "DEBIAN_TEMPLATE=\"${DEBIAN_TEMPLATE}\""
  echo "APP_PORT=\"${APP_PORT}\""
  echo "LXC_RAM=\"${LXC_RAM}\""
  echo "LXC_DISK=\"${LXC_DISK}\""
  echo "LXC_CORES=\"${LXC_CORES}\""
  echo "STORAGE=\"${STORAGE}\""
  echo "APP_DIR=\"${APP_DIR}\""
  echo "REPO_URL=\"${REPO_URL}\""

  if [[ -n "${CF_API_TOKEN:-}" ]]; then
    echo "CF_API_TOKEN=\"${CF_API_TOKEN}\""
    echo "CF_ACCOUNT_ID=\"${CF_ACCOUNT_ID:-}\""
    echo "CF_ZONE_ID=\"${CF_ZONE_ID:-}\""
    echo "CF_DOMAIN=\"${CF_DOMAIN:-}\""
    echo "CF_SUBDOMAIN=\"${CF_SUBDOMAIN}\""
  fi

  if [[ -n "${GH_PAT:-}" ]]; then
    echo "GH_PAT=\"${GH_PAT}\""
  fi

  echo ""
  echo "NGINX_LISTEN=\"${NGINX_LISTEN}\""
  echo ""

  # Inline common.sh but skip render_template (baked values make it simpler)
  echo "# ── Common ──"
  strip_shebang "${SCRIPT_DIR}/lib/common.sh"
  echo ""

  # Override render_template for inline use (SCRIPT_DIR won't exist)
  cat << 'RENDER_OVERRIDE'

# Override template functions for single-file mode
SCRIPT_DIR=""
render_template() { cat "$1"; }  # templates are pre-baked, not used in single-file
RENDER_OVERRIDE

  echo ""
  echo "# ── Preflight ──"
  # Inline a simplified preflight (no config loading needed)
  cat << 'PREFLIGHT'
if ! command -v pct &>/dev/null; then
  error "This script must be run on a Proxmox VE host (pct not found)"
fi

if [[ -f /root/.ssh/id_ed25519 ]]; then
  success "SSH key found: /root/.ssh/id_ed25519"
elif [[ -f /root/.ssh/id_rsa ]]; then
  success "SSH key found: /root/.ssh/id_rsa"
else
  warn "No SSH key found. Generate one with: ssh-keygen -t ed25519"
fi
PREFLIGHT

  echo ""
  echo "# ── Confirm ──"
  cat << 'CONFIRM_BLOCK'
header "Proxmox LXC Deploy"
info "App: ${REPO_NAME}"
info "Repo: ${REPO_URL}"
info "Port: ${APP_PORT}"
info "Specs: ${LXC_CORES} core(s), ${LXC_RAM}MB RAM, ${LXC_DISK}GB disk"
echo ""
read -rp "$(echo -e "${BOLD}Proceed? [Y/n]${NC} ")" CONFIRM
[[ "${CONFIRM,,}" == "n" ]] && exit 0
CONFIRM_BLOCK

  echo ""
  echo "# ── LXC ──"
  strip_shebang "${SCRIPT_DIR}/lib/lxc.sh"
  echo ""

  echo "# ── Dependencies ──"
  strip_shebang "${SCRIPT_DIR}/lib/deps.sh"
  echo ""

  echo "# ── Ruby ──"
  strip_shebang "${SCRIPT_DIR}/lib/ruby.sh"
  echo ""

  echo "# ── App ──"
  strip_shebang "${SCRIPT_DIR}/lib/app.sh"
  echo ""

  echo "# ── Deploy User ──"
  strip_shebang "${SCRIPT_DIR}/lib/deploy-user.sh"
  echo ""

  echo "# ── Systemd ──"
  # Inline the rendered template as a function
  systemd_content=$(process_template "${SCRIPT_DIR}/templates/systemd.service.tmpl")
  cat << SYSTEMD_FUNC
setup_systemd() {
  header "Creating Systemd Service"

  pct exec "\${CTID}" -- bash -c "cat > /etc/systemd/system/\${REPO_NAME}.service << 'SERVICE_EOF'
${systemd_content}
SERVICE_EOF

systemctl daemon-reload
systemctl enable \${REPO_NAME}
systemctl start \${REPO_NAME}"
  success "Service \${REPO_NAME} created and started"
}
SYSTEMD_FUNC

  echo ""
  echo "# ── Nginx ──"
  nginx_content=$(process_template "${SCRIPT_DIR}/templates/nginx.conf.tmpl")
  cat << NGINX_FUNC
setup_nginx() {
  header "Configuring Nginx"

  pct exec "\${CTID}" -- bash -c "cat > /etc/nginx/sites-available/\${REPO_NAME} << 'NGINX_EOF'
${nginx_content}
NGINX_EOF

rm -f /etc/nginx/sites-enabled/default
ln -sf /etc/nginx/sites-available/\${REPO_NAME} /etc/nginx/sites-enabled/\${REPO_NAME}
nginx -t 2>&1 && systemctl reload nginx"
  success "Nginx configured"
}
NGINX_FUNC

  # Cloudflare module (conditional)
  if [[ -n "${CF_API_TOKEN:-}" ]]; then
    echo ""
    echo "# ── Cloudflare ──"
    strip_shebang "${SCRIPT_DIR}/lib/cloudflare.sh"
  fi

  # GitHub Actions module (conditional)
  if [[ -n "${GH_PAT:-}" ]]; then
    echo ""
    echo "# ── GitHub Actions ──"
    strip_shebang "${SCRIPT_DIR}/lib/github-actions.sh"

    # Inline the rendered deploy.yml template as a variable
    workflow_content=$(process_template "${SCRIPT_DIR}/templates/deploy.yml.tmpl")
    echo ""
    echo "# Pre-rendered workflow template"
    echo "DEPLOY_WORKFLOW_CONTENT=\$(cat << 'WORKFLOW_EOF'"
    echo "${workflow_content}"
    echo "WORKFLOW_EOF"
    echo ")"
  fi

  echo ""
  echo "# ── Run ──"
  cat << 'RUN_BLOCK'
header "Creating LXC Container"
lxc_next_id
lxc_ensure_template
lxc_create
lxc_start
lxc_push_ssh_keys
install_system_deps
install_ruby
deploy_app
create_deploy_user
create_deploy_script
setup_systemd
setup_nginx
RUN_BLOCK

  if [[ -n "${CF_API_TOKEN:-}" ]]; then
    echo "cf_setup"
  fi

  if [[ -n "${GH_PAT:-}" ]]; then
    echo "gh_setup"
  fi

  # Summary
  cat << 'SUMMARY'

header "Deployment Complete!"
echo -e "${GREEN}${BOLD}App:${NC}         ${REPO_NAME}"
echo -e "${GREEN}${BOLD}Container:${NC}   ${CTID}"
echo -e "${GREEN}${BOLD}IP:${NC}          ${LXC_IP}"
SUMMARY

  if [[ -n "${CF_API_TOKEN:-}" ]]; then
    echo "echo -e \"\${GREEN}\${BOLD}URL:\${NC}         https://${CF_SUBDOMAIN}.${CF_DOMAIN}\""
  else
    echo "echo -e \"\${GREEN}\${BOLD}URL:\${NC}         http://\${LXC_IP}\""
  fi

  cat << 'SUMMARY2'
echo -e "${GREEN}${BOLD}App Dir:${NC}     ${APP_DIR}"
echo -e "${GREEN}${BOLD}SSH:${NC}         ssh deploy@${LXC_IP}"
echo -e "${GREEN}${BOLD}Logs:${NC}        pct exec ${CTID} -- journalctl -u ${REPO_NAME} -f"
echo -e "${GREEN}${BOLD}Redeploy:${NC}    ssh deploy@${LXC_IP} '${APP_DIR}/bin/deploy'"
SUMMARY2

  if [[ -z "${GH_PAT:-}" ]]; then
    cat << 'MANUAL_GH'

DEPLOY_KEY=$(get_deploy_private_key)
echo ""
echo -e "${YELLOW}${BOLD}── GitHub Actions Setup ──${NC}"
echo -e "Add these secrets to your GitHub repo (${GITHUB_USER}/${REPO_NAME}):"
echo -e "  ${BOLD}DEPLOY_HOST${NC}     = ${LXC_IP}"
echo -e "  ${BOLD}DEPLOY_USER${NC}     = deploy"
echo -e "  ${BOLD}DEPLOY_SSH_KEY${NC}  = (the private key below)"
echo ""
echo -e "${YELLOW}${BOLD}── Deploy Private Key ──${NC}"
echo -e "${RED}Save this now - it won't be shown again!${NC}"
echo ""
echo "${DEPLOY_KEY}"
MANUAL_GH
  fi

  echo ""
  echo "echo -e \"\${GREEN}\${BOLD}Done!\${NC}\""

} > "${OUTPUT}"

chmod +x "${OUTPUT}"
echo "Generated: ${OUTPUT}"
echo "Paste the contents into your Proxmox VE terminal or transfer the file."
